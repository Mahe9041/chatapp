{
  "compilerOptions": {
    "target":                     "ES2020",
    "module":                     "CommonJS",
    "lib":                        ["ES2020"],
    "outDir":                     "./dist",
    "rootDir":                    "../",
    "strict":                     true,
    "esModuleInterop":            true,
    "skipLibCheck":               true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":          true,
    "declaration":                true,
    "baseUrl":                    ".",
    "paths": {
      "@chatapp/shared": ["../shared/types/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../shared/types/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}