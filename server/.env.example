# =============================================================================
# server/.env.example
# Copy to .env and fill in your values.
# Never commit .env to git — it's in .gitignore.
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate secrets with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_64_char_random_secret_do_not_use_this_value_abc123
JWT_REFRESH_SECRET=replace_with_another_64_char_random_secret_different_from_above
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# ── MongoDB (Atlas) ───────────────────────────────────────────────────────────
# Get from: cloud.mongodb.com → Connect → Drivers → copy connection string
MONGODB_URI=mongodb+srv://[USERNAME]:[PASSWORD]@cluster0.xxxxx.mongodb.net/chatapp?retryWrites=true&w=majority

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from: console.upstash.com → your database → Details → REST URL (use Redis URL)
REDIS_URL=rediss://:[PASSWORD]@[ENDPOINT].upstash.io:6380

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
# Get from: dash.cloudflare.com → R2 → your bucket → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=chatapp-media
CDN_BASE_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ── Push notifications (optional for Phase 1) ─────────────────────────────────
# FCM_SERVER_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173